# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.

# Ignore Mac/Linux/Windows hidden and system files
.DS_Store
Thumbs.db

# Common VCS dirsa
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/

# Editor & IDE files
.idea/
.vscode/
*.sw?
*.swo
*.swp
*.tmp
*.bak
*.orig
*~
.project
*.tmproj

# Documentation and meta not needed in chart package
README*
LICENSE*
NOTES.txt

# This wrapper chart: ONLY these are ever needed:
#   Chart.yaml
#   values.yaml
#   values-local.yaml
#   charts/
#   Chart.lock
#   templates/ (keep, only needed YAMLs should be here)
# (No negation needed since by default helm includes only these if not ignored)

# Ignore any other stray files
*
!Chart.yaml
!values.yaml
!values-local.yaml
!charts/
!templates/
!Chart.lock

