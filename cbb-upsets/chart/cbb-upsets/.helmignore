# Patterns to ignore when building packages.
# Helm automatically includes `Chart.yaml`, `values.yaml`, `values-local.yaml`, `charts/`, `templates/`, and `Chart.lock`,
# so we only need to list files we explicitly want excluded.
.DS_Store
Thumbs.db

# Version control metadata
.git/
.gitignore
.hg/
.hgignore
.svn/
.bzr/
.bzrignore

# IDE / editor artifacts
.idea/
.vscode/
*.sw?
*.swo
*.swp
*.tmp
*.bak
*.orig
*~

# Documentation that shouldn't be packaged
README*
LICENSE*
